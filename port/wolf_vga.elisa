@test
def vga_decodes_status_bar() -> void:
    can Abort.Panic:
        v: mutable Vga = zeroed
        root: cstr = "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-wolf3d/WOLF3D/"
        if not vga_load(&v,
            "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-wolf3d/WOLF3D/VGADICT.WL6",
            "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-wolf3d/WOLF3D/VGAHEAD.WL6",
            "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-wolf3d/WOLF3D/VGAGRAPH.WL6"):
            panic("failed to load VGAGRAPH set")
        if v.num_pics < 80:
            panic("pic table too small")
        pic: mutable array[u8, 70000] = zeroed
        w: mutable i32 = 0
        h: mutable i32 = 0
        if not vga_get_pic(&v, STATUSBARPIC, &pic[0], &w, &h):
            panic("failed to decode STATUSBARPIC")
        # Wolf status bar is 320x40
        if w != 320 or h != 40:
            panic("status bar wrong dimensions")
        # must not be a flat color (real decoded art varies)
        first: u8 = pic[0u32]
        varied: mutable bool = false
        for i in 0..<(w * h):
            if pic[i.usize()] != first:
                varied <- true
        if not varied:
            panic("status bar decoded to a flat color (huffman/deplane wrong)")
        # dump for visual verification
        out: void&? = fopen("/tmp/wolf_statusbar.bin".cast[u8&], "wb".cast[u8&])
        if out != null:
            _ = fwrite(&pic[0], 1.usize(), (w * h).usize(), out)
            _ = fclose(out)
        # decode the full-screen title screen (320x200) for the menu front-end
        tw: mutable i32 = 0
        th: mutable i32 = 0
        if not vga_get_pic(&v, 87, &pic[0], &tw, &th):     # TITLEPIC
            panic("failed to decode TITLEPIC")
        if tw != 320 or th != 200:
            panic("title pic wrong size")
        tout: void&? = fopen("/tmp/wolf_title.bin".cast[u8&], "wb".cast[u8&])
        if tout != null:
            _ = fwrite(&pic[0], 1.usize(), 64000.usize(), tout)
            _ = fclose(tout)
        # font: render menu text onto a band for visual verification
        if v.font_height <= 0 or v.font_height > 32:
            panic("font height implausible (chunk decode wrong)")
        band: mutable array[u8, 25600] = zeroed   # 320x80
        for i in 0..<25600:
            band[i.usize()] <- 28u8
        _ = vga_draw_string(&v, &band[0], 320, 320, 80, 20, 10, "NEW GAME".cast[u8&], 16u8)
        _ = vga_draw_string(&v, &band[0], 320, 320, 80, 20, 30, "SOUND".cast[u8&], 16u8)
        _ = vga_draw_string(&v, &band[0], 320, 320, 80, 20, 50, "QUIT".cast[u8&], 16u8)
        fout: void&? = fopen("/tmp/wolf_font.bin".cast[u8&], "wb".cast[u8&])
        if fout != null:
            _ = fwrite(&band[0], 1.usize(), 25600.usize(), fout)
            _ = fclose(fout)
        # composite a pause menu over the title (mirrors draw_menu) for visual verification
        _ = vga_get_pic(&v, 87, &pic[0], &tw, &th)
        bx: i32 = 96
        by: i32 = 64
        for yy in by..<(by + 76):
            for xx in bx..<(bx + 128):
                edge: bool = yy == by or yy == by + 75 or xx == bx or xx == bx + 127
                cc: mutable u8 = 0u8
                if edge:
                    cc <- 15u8
                pic[(yy * 320 + xx).usize()] <- cc
        _ = vga_draw_string(&v, &pic[0], 320, 320, 200, bx + 22, by + 12, "RESUME".cast[u8&], 15u8)
        _ = vga_draw_string(&v, &pic[0], 320, 320, 200, bx + 22, by + 32, "NEW GAME".cast[u8&], 31u8)
        _ = vga_draw_string(&v, &pic[0], 320, 320, 200, bx + 22, by + 52, "QUIT".cast[u8&], 31u8)
        _ = vga_draw_string(&v, &pic[0], 320, 320, 200, bx + 8, by + 12, ">".cast[u8&], 15u8)
        mout: void&? = fopen("/tmp/wolf_menu.bin".cast[u8&], "wb".cast[u8&])
        if mout != null:
            _ = fwrite(&pic[0], 1.usize(), 64000.usize(), mout)
            _ = fclose(mout)
        # authentic main menu composite (mirrors draw_main_menu): bronze bg, logo, window, items, gun
        for i in 0..<64000:
            pic[i.usize()] <- 0x29u8
        for yy in 10..<34:
            for xx in 0..<320:
                pic[(yy * 320 + xx).usize()] <- 0u8
        for xx in 0..<320:
            pic[(32 * 320 + xx).usize()] <- 0x2Cu8
        logo: mutable array[u8, 32000] = zeroed
        lw: mutable i32 = 0
        lh: mutable i32 = 0
        gun: mutable array[u8, 4096] = zeroed
        gw: mutable i32 = 0
        gh: mutable i32 = 0
        _ = vga_get_pic(&v, 10, &logo[0], &lw, &lh)
        _ = vga_get_pic(&v, 11, &gun[0], &gw, &gh)
        for yy in 0..<lh:
            for xx in 0..<lw:
                if (84 + xx) < 320 and yy < 200:
                    pic[(yy * 320 + 84 + xx).usize()] <- logo[(yy * lw + xx).usize()]
        for yy in 52..<188:
            for xx in 68..<246:
                pic[(yy * 320 + xx).usize()] <- 0x2Du8
        sel: i32 = 0
        for it in 0..<10:
            col: mutable u8 = 0x17u8
            if it == 4:
                col <- 0x2Bu8
            elif it == sel:
                col <- 0x13u8
            yrow: i32 = 55 + it * 13
            if it == 0:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "New Game".cast[u8&], col)
            elif it == 1:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "Sound".cast[u8&], col)
            elif it == 2:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "Control".cast[u8&], col)
            elif it == 3:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "Load Game".cast[u8&], col)
            elif it == 4:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "Save Game".cast[u8&], col)
            elif it == 5:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "Change View".cast[u8&], col)
            elif it == 6:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "Read This!".cast[u8&], col)
            elif it == 7:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "View Scores".cast[u8&], col)
            elif it == 8:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "Back to Demo".cast[u8&], col)
            else:
                _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 100, yrow, "Quit".cast[u8&], col)
        for yy in 0..<gh:
            for xx in 0..<gw:
                pic[((53 + sel * 13 + yy) * 320 + 76 + xx).usize()] <- gun[(yy * gw + xx).usize()]
        mmout: void&? = fopen("/tmp/wolf_mainmenu.bin".cast[u8&], "wb".cast[u8&])
        if mmout != null:
            _ = fwrite(&pic[0], 1.usize(), 64000.usize(), mmout)
            _ = fclose(mmout)
        # episode-select composite: bg + window + 6 episode pics (C_EPISODE1PIC=30..35) + gun
        for i in 0..<64000:
            pic[i.usize()] <- 0x29u8
        for yy in 19..<181:
            for xx in 6..<314:
                pic[(yy * 320 + xx).usize()] <- 0x2Du8
        _ = vga_draw_string(&v, &pic[0], 320, 320, 200, 72, 4, "Which episode to play?".cast[u8&], 0x47u8)
        escr: mutable array[u8, 20000] = zeroed
        for i in 0..<6:
            ew: mutable i32 = 0
            eh: mutable i32 = 0
            if vga_get_pic(&v, 30 + i, &escr[0], &ew, &eh):
                for yy in 0..<eh:
                    for xx in 0..<ew:
                        dx: i32 = 42 + xx
                        dy: i32 = 23 + i * 26 + yy
                        if dx < 320 and dy < 200:
                            pic[(dy * 320 + dx).usize()] <- escr[(yy * ew + xx).usize()]
        for yy in 0..<gh:
            for xx in 0..<gw:
                pic[((22 + 0 * 26 + yy) * 320 + 12 + xx).usize()] <- gun[(yy * gw + xx).usize()]
        eout: void&? = fopen("/tmp/wolf_episode.bin".cast[u8&], "wb".cast[u8&])
        if eout != null:
            _ = fwrite(&pic[0], 1.usize(), 64000.usize(), eout)
            _ = fclose(eout)
        # composite the authentic HUD numbers onto the real status bar (mirrors hud_latch)
        sbar: mutable array[u8, 12800] = zeroed
        sw2: mutable i32 = 0
        sh2: mutable i32 = 0
        _ = vga_get_pic(&v, STATUSBARPIC, &sbar[0], &sw2, &sh2)
        digits: mutable array[u8, 4096] = zeroed
        dpic: mutable array[u8, 512] = zeroed
        ddw: mutable i32 = 0
        ddh: mutable i32 = 0
        for slot in 0..<11:
            _ = vga_get_pic(&v, 98 + slot, &dpic[0], &ddw, &ddh)
            for k in 0..<(ddw * ddh):
                digits[(slot * ddw * ddh + k).usize()] <- dpic[k.usize()]
        # blit health "100" (x=21) and ammo "99" (x=27), y=16, into the 320x40 bar
        blit_latch(&digits[0], ddw, ddh, &sbar[0], 21, 16, 3, 100)
        blit_latch(&digits[0], ddw, ddh, &sbar[0], 27, 16, 2, 99)
        blit_latch(&digits[0], ddw, ddh, &sbar[0], 2, 16, 2, 1)
        blit_latch(&digits[0], ddw, ddh, &sbar[0], 6, 16, 6, 1300)
        hout: void&? = fopen("/tmp/wolf_hud.bin".cast[u8&], "wb".cast[u8&])
        if hout != null:
            _ = fwrite(&sbar[0], 1.usize(), 12800.usize(), hout)
            _ = fclose(hout)

@test
def vga_dumps_helpart() -> void:
    can Abort.Panic:
        v: mutable Vga = zeroed
        if not vga_load(&v,
            "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-wolf3d/WOLF3D/VGADICT.WL6",
            "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-wolf3d/WOLF3D/VGAHEAD.WL6",
            "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-wolf3d/WOLF3D/VGAGRAPH.WL6"):
            panic("failed to load VGAGRAPH set")
        txt: mutable array[u8, 16000] = zeroed
        n: i32 = vga_get_text(&v, 138, &txt[0], 16000)   # T_HELPART
        if n <= 0:
            panic("helpart decoded empty")
        out: void&? = fopen("/tmp/wolf_helpart.txt".cast[u8&], "wb".cast[u8&])
        if out != null:
            _ = fwrite(&txt[0], 1.usize(), n.usize(), out)
            _ = fclose(out)

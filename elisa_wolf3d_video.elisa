def vl_fade_out_from_host(start: i32, end: i32, red: i32, green: i32, blue: i32, steps: i32) -> i32 can[Game.Run, Video.Palette, Video.Surface, Video.Fizzle, Unsafe.RawExtern]:
    can Game.Run, Video.Palette, Video.Surface, Video.Fizzle, Unsafe.RawExtern:
        palette1: mutable u8[1024] = zeroed
        palette2: mutable u8[1024] = zeroed

        if validate_fade_steps(steps.u32()) != 0:
            return -1
        if wolf3d_legacy_vl_get_palette(palette1[0].ref[mutable u8&]) != 0:
            return -1

        i: mutable i32 = 0
        while i < steps:
            if build_fade_out_sdl_palette(palette1[0].ref[u8&], palette2[0].ref[mutable u8&], start, end, red, green, blue, i, steps, 256) != 0:
                return -1
            if wolf3d_legacy_get_usedoublebuffering() == 0 or wolf3d_legacy_get_screen_bits() == 8:
                sdl_delay_raw(8.u32())
            _ = wolf3d_legacy_vl_set_palette(palette2[0].ref[mutable u8&], 1)
            i <- i + 1

        red6: i32 = fade_scale_6bit_color_component(red)
        green6: i32 = fade_scale_6bit_color_component(green)
        blue6: i32 = fade_scale_6bit_color_component(blue)
        _ = wolf3d_legacy_vl_fill_palette(red6, green6, blue6)
        return 0

def vl_fade_in_from_host(start: i32, end: i32, palette: mutable u8&, steps: i32) -> i32 can[Game.Run, Video.Palette, Video.Surface, Video.Fizzle, Unsafe.RawExtern]:
    can Game.Run, Video.Palette, Video.Surface, Video.Fizzle, Unsafe.RawExtern:
        palette1: mutable u8[1024] = zeroed
        palette2: mutable u8[1024] = zeroed

        if validate_fade_steps(steps.u32()) != 0:
            return -1
        if wolf3d_legacy_vl_get_palette(palette1[0].ref[mutable u8&]) != 0:
            return -1

        i: mutable i32 = 0
        while i < steps:
            if build_fade_in_sdl_palette(palette1[0].ref[u8&], palette, palette2[0].ref[mutable u8&], start, end, i, steps, 256) != 0:
                return -1
            if wolf3d_legacy_get_usedoublebuffering() == 0 or wolf3d_legacy_get_screen_bits() == 8:
                sdl_delay_raw(8.u32())
            _ = wolf3d_legacy_vl_set_palette(palette2[0].ref[mutable u8&], 1)
            i <- i + 1

        _ = wolf3d_legacy_vl_set_palette(palette, 1)
        return 0


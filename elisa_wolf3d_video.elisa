        font_locations[65] <- 0.i16()
        font_width[65] <- 2.u8()
        font_base[0] <- 1.u8()
        font_base[1] <- 0.u8()
        font_base[2] <- 0.u8()
        font_base[3] <- 1.u8()
        text[0] <- 65.u8()


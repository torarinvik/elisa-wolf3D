permission Video:
    Fizzle
    Geometry
    Picture
    Palette
    Surface
    Text

permission Input:
    Poll

permission Game:
    Run

const wolf3d_latchpics_lump_start: i32 = 91

@link_name(SDL_BlitSurface)
extern sdl_blit_surface_raw(source: mutable void&?, source_rect: mutable void&?, dest: mutable void&?, dest_rect: mutable void&?) -> bool effects[Video.Surface, Unsafe.RawExtern]

@link_name(CRT_DAC)
extern crt_dac_raw() -> void effects[Video.Surface, Unsafe.RawExtern]

@link_name(SDL_GetTicks)
extern sdl_get_ticks_raw() -> u32 effects[Unsafe.RawExtern]

@link_name(SDL_Delay)
extern sdl_delay_raw(ms: u32) -> void effects[Unsafe.RawExtern]

extern wolf3d_legacy_get_scale_factor() -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_latchpic_surface(index: i32) -> mutable void&? effects[Video.Surface, Unsafe.RawExtern]
extern wolf3d_legacy_vl_latch_to_screen_scaled_coord(source: mutable void&?, xsrc: i32, ysrc: i32, width: i32, height: i32, scxdest: i32, scydest: i32) -> i32 effects[Video.Surface, Unsafe.RawExtern]
extern wolf3d_legacy_get_latchpic_dimensions(picnum: i32, width: mutable i32&, height: mutable i32&) -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_in_start_ack() -> i32 effects[Input.Poll, Unsafe.RawExtern]
extern wolf3d_legacy_in_check_ack() -> i32 effects[Input.Poll, Unsafe.RawExtern]
extern wolf3d_legacy_vl_get_palette(palette: mutable u8&) -> i32 effects[Video.Palette, Unsafe.RawExtern]
extern wolf3d_legacy_vl_set_palette(palette: mutable u8&, forceupdate: i32) -> i32 effects[Video.Palette, Unsafe.RawExtern]
extern wolf3d_legacy_vl_fill_palette(red: i32, green: i32, blue: i32) -> i32 effects[Video.Palette, Unsafe.RawExtern]
extern wolf3d_legacy_get_usedoublebuffering() -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_screen_bits() -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_screen_width() -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_screen_height() -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_screen_pitch() -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_buffer_pitch() -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_cur_pitch() -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_screen_surface() -> mutable void&? effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_screen_buffer_surface() -> mutable void&? effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_cur_surface() -> mutable void&? effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_get_game_palette() -> mutable void&? effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_set_screen_width(screen_width: i32) -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_set_screen_height(screen_height: i32) -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_set_screen_bits(screen_bits: i32) -> i32 effects[Game.Run, Unsafe.RawExtern]
extern wolf3d_legacy_set_usedoublebuffering(usedoublebuffering: i32) -> i32 effects[Game.Run, Unsafe.RawExtern]

def log2_ceil_impl(value: u32) -> i32 can[Video.Geometry]:
    can Video.Geometry:
        signal Video.Geometry

    n: mutable i32 = 0
    v: mutable u32 = 1

    while v < value:
        n <- n + 1
        v <- v << 1

    return n

def fizzle_mask_for_bits(bits: i32) -> u32 can[Video.Fizzle]:
    can Video.Fizzle:
        signal Video.Fizzle

    if bits <= 17:
        return 0x00012000
    if bits == 18:
        return 0x00020400
    if bits == 19:
        return 0x00040023
    if bits == 20:
        return 0x00090000
    if bits == 21:
        return 0x00140000
    if bits == 22:
        return 0x00300000
    if bits == 23:
        return 0x00420000
    if bits == 24:
        return 0x00e10000
    return 0x01200000

def fizzle_advance(rndval: u32, rndmask: u32) -> u32 can[Video.Fizzle]:
    can Video.Fizzle:
        signal Video.Fizzle

    if rndval & 1.u32() != 0.u32():
        return rndval >> 1
    return (rndval >> 1) ^ rndmask

error VideoPictureError:
    WidthNotDivisibleBy4

error VideoFadeError:
    ZeroFrames
    ZeroSteps

error VideoColorError:
    PaletteIndexOutOfRange

error VideoCoordinateError:
    OutOfBounds
    NonPositiveScale

def checked_munge_pic_width(width: u32) -> i32 error[VideoPictureError] can[Video.Picture]:
    if width & 3 != 0.u32():
        raise VideoPictureError.WidthNotDivisibleBy4

    can Video.Picture:
        signal Video.Picture
    return 0

def validate_munge_pic_width(width: u32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return try checked_munge_pic_width(width) else -1

def munge_pic_from_temp(source: mutable u8&, temp: u8&, width: u32, height: u32) -> i32 can[Video.Picture]:
    pwidth: usize = (width / 4).usize()
    dest_index: mutable usize = 0

    can Video.Picture:
        signal Video.Picture

        for plane in 0..<4.usize():
            for y in 0..<height.usize():
                base: usize = y * width.usize()
                for x in 0..<pwidth:
                    source[dest_index] <- temp[base + x * 4 + plane]
                    dest_index <- dest_index + 1

    return 0

def align_picture_x(x: i32) -> i32 can[Video.Geometry]:
    can Video.Geometry:
        signal Video.Geometry
    return x & -8

def pic_index_for_chunk(chunknum: i32, startpics: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        signal Video.Picture
    return chunknum - startpics

def latchpic_index(picnum: i32, latchpics_lump_start: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        signal Video.Picture
    return 2 + picnum - latchpics_lump_start

def latch_tile_surface_height(num_tiles: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        signal Video.Picture
    return ((num_tiles + 7) / 8) * 8

def latch_tile_dest_x(tile_index: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        signal Video.Picture
    return (tile_index & 7) * 8

def latch_tile_dest_y(tile_index: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        signal Video.Picture
    return (tile_index >> 3) * 8

def fizzle_pixels_per_frame(width: u32, height: u32, frames: u32) -> u32 can[Video.Fizzle]:
    if frames == 0.u32():
        return 0.u32()

    can Video.Fizzle:
        signal Video.Fizzle

    return width * height / frames

def configure_fizzle_state(width: u32, height: u32, rndbits_y: mutable u32&, rndmask: mutable u32&) -> i32 can[Video.Fizzle, Video.Geometry]:
    can Video.Fizzle:
        signal Video.Fizzle

    can Video.Geometry:
        signal Video.Geometry

    can Video.Geometry:
        rndbits_y[0] <- log2_ceil_impl(height).u32()

    can Video.Fizzle, Video.Geometry:
        rndmask[0] <- fizzle_mask_for_dimensions(width, height)
        return fizzle_bits_for_dimensions(width, height)

def next_fizzle_first(usedoublebuffering: i32, current_first: i32) -> i32 can[Video.Fizzle]:
    can Video.Fizzle:
        signal Video.Fizzle

    if usedoublebuffering != 0:
        return 0
    return current_first

def draw_block_for_plot(scale: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        signal Video.Picture

    if scale == 1:
        return 0
    return 1

def planar_source_index(width: i32, height: i32, x: usize, y: usize) -> usize can[Video.Picture]:
    pwidth: usize = (width / 4).usize()

    can Video.Picture:
        signal Video.Picture

    plane: usize = x - (x / 4) * 4
    return y * pwidth + (x / 4) + plane * pwidth * height.usize()

def copy_planar_to_linear(source: u8&, dest: mutable u8&, width: i32, height: i32, dest_pitch: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        signal Video.Picture

        for y in 0..<height.usize():
            for x in 0..<width.usize():
                dest[y * dest_pitch.usize() + x] <- source[planar_source_index(width, height, x, y)]

    return 0

def draw_planar_scaled_to_linear(source: u8&, dest: mutable u8&, width: i32, height: i32, dest_x: i32, dest_y: i32, scale: i32, dest_pitch: i32) -> i32 can[Video.Picture]:
    if scale <= 0:
        return -1

    can Video.Picture:
        scale_usize: usize = scale.usize()
        dest_x_usize: usize = dest_x.usize()
        dest_y_usize: usize = dest_y.usize()
        pitch: usize = dest_pitch.usize()

        for y in 0..<height.usize():
            scaled_y: usize = y * scale_usize
            for x in 0..<width.usize():
                scaled_x: usize = x * scale_usize
                col: u8 = source[planar_source_index(width, height, x, y)]
                for sy in 0..<scale_usize:
                    for sx in 0..<scale_usize:
                        dest[(dest_y_usize + scaled_y + sy) * pitch + dest_x_usize + scaled_x + sx] <- col

    return 0

def draw_planar_region_scaled_to_linear(source: u8&, dest: mutable u8&, orig_width: i32, orig_height: i32, src_x: i32, src_y: i32, dest_x: i32, dest_y: i32, width: i32, height: i32, scale: i32, dest_pitch: i32) -> i32 can[Video.Picture]:
    if scale <= 0:
        return -1

    can Video.Picture:
        scale_usize: usize = scale.usize()
        src_x_usize: usize = src_x.usize()
        src_y_usize: usize = src_y.usize()
        dest_x_usize: usize = dest_x.usize()
        dest_y_usize: usize = dest_y.usize()
        pitch: usize = dest_pitch.usize()

        for y in 0..<height.usize():
            scaled_y: usize = y * scale_usize
            for x in 0..<width.usize():
                scaled_x: usize = x * scale_usize
                col: u8 = source[planar_source_index(orig_width, orig_height, src_x_usize + x, src_y_usize + y)]
                for sy in 0..<scale_usize:
                    for sx in 0..<scale_usize:
                        dest[(dest_y_usize + scaled_y + sy) * pitch + dest_x_usize + scaled_x + sx] <- col

    return 0

def copy_linear_scaled_to_linear(source: u8&, dest: mutable u8&, src_x: i32, src_y: i32, width: i32, height: i32, dest_x: i32, dest_y: i32, scale: i32, source_pitch: i32, dest_pitch: i32) -> i32 can[Video.Picture]:
    if scale <= 0:
        return -1

    can Video.Picture:
        scale_usize: usize = scale.usize()
        src_x_usize: usize = src_x.usize()
        src_y_usize: usize = src_y.usize()
        dest_x_usize: usize = dest_x.usize()
        dest_y_usize: usize = dest_y.usize()
        source_pitch_usize: usize = source_pitch.usize()
        dest_pitch_usize: usize = dest_pitch.usize()

        for y in 0..<height.usize():
            scaled_y: usize = y * scale_usize
            for x in 0..<width.usize():
                scaled_x: usize = x * scale_usize
                col: u8 = source[(src_y_usize + y) * source_pitch_usize + src_x_usize + x]
                for sy in 0..<scale_usize:
                    for sx in 0..<scale_usize:
                        dest[(dest_y_usize + scaled_y + sy) * dest_pitch_usize + dest_x_usize + scaled_x + sx] <- col

    return 0

def fill_linear_span(dest: mutable u8&, width: i32, color: i32) -> i32 can[Video.Picture]:
    if width < 0:
        return -1

    can Video.Picture:
        signal Video.Picture

        value: u8 = color.u8()
        for x in 0..<width.usize():
            dest[x] <- value

    return 0

def fill_linear_vline(dest: mutable u8&, height: i32, pitch: i32, color: i32) -> i32 can[Video.Picture]:
    if height < 0:
        return -1

    can Video.Picture:
        signal Video.Picture

        value: u8 = color.u8()
        pitch_usize: usize = pitch.usize()
        for y in 0..<height.usize():
            dest[y * pitch_usize] <- value

    return 0

def fill_linear_rect(dest: mutable u8&, width: i32, height: i32, pitch: i32, color: i32) -> i32 can[Video.Picture]:
    if width < 0 or height < 0:
        return -1

    can Video.Picture:
        signal Video.Picture

        value: u8 = color.u8()
        pitch_usize: usize = pitch.usize()
        for y in 0..<height.usize():
            row: usize = y * pitch_usize
            for x in 0..<width.usize():
                dest[row + x] <- value

    return 0

def draw_pixel_on_linear_buffer(dest: mutable u8&, x: i32, y: i32, color: i32, pitch: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        if validate_pixel_bounds(x, y, screen_width, screen_height) != 0:
            return -1

        dest[y.usize() * pitch.usize() + x.usize()] <- color.u8()

    return 0

def get_pixel_from_linear_buffer(source: u8&, x: i32, y: i32, pitch: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        if validate_pixel_bounds(x, y, screen_width, screen_height) != 0:
            return -1

        return source[y.usize() * pitch.usize() + x.usize()].i32()

def draw_hline_on_linear_buffer(dest: mutable u8&, x: i32, y: i32, width: i32, color: i32, pitch: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        if validate_hline_bounds(x, y, width, screen_width, screen_height) != 0:
            return -1

        offset: usize = y.usize() * pitch.usize() + x.usize()
        return fill_linear_span(dest[offset].ref[mutable u8&], width, color)

def draw_vline_on_linear_buffer(dest: mutable u8&, x: i32, y: i32, height: i32, color: i32, pitch: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        if validate_vline_bounds(x, y, height, screen_width, screen_height) != 0:
            return -1

        offset: usize = y.usize() * pitch.usize() + x.usize()
        return fill_linear_vline(dest[offset].ref[mutable u8&], height, pitch, color)

def draw_bar_scaled_coord_on_linear_buffer(dest: mutable u8&, scx: i32, scy: i32, scwidth: i32, scheight: i32, color: i32, pitch: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        if validate_bar_bounds(scx, scy, scwidth, scheight, screen_width, screen_height) != 0:
            return -1

        offset: usize = scy.usize() * pitch.usize() + scx.usize()
        return fill_linear_rect(dest[offset].ref[mutable u8&], scwidth, scheight, pitch, color)

def draw_logical_plot_on_linear_buffer(dest: mutable u8&, x: i32, y: i32, color: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        if scale <= 0:
            return -1

        if scale == 1:
            return draw_pixel_on_linear_buffer(dest, x, y, color, pitch, screen_width, screen_height)

        return draw_bar_scaled_coord_on_linear_buffer(dest, x * scale, y * scale, scale, scale, color, pitch, screen_width, screen_height)

def draw_logical_hline_on_linear_buffer(dest: mutable u8&, x1: i32, x2: i32, y: i32, color: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture, Video.Geometry]:
    can Video.Picture, Video.Geometry:
        if scale <= 0:
            return -1

        span: i32 = inclusive_span_length(x1, x2)
        if span < 0:
            return -1
        return draw_bar_scaled_coord_on_linear_buffer(dest, x1 * scale, y * scale, span * scale, scale, color, pitch, screen_width, screen_height)

def draw_logical_vline_on_linear_buffer(dest: mutable u8&, y1: i32, y2: i32, x: i32, color: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture, Video.Geometry]:
    can Video.Picture, Video.Geometry:
        if scale <= 0:
            return -1

        span: i32 = inclusive_span_length(y1, y2)
        if span < 0:
            return -1
        return draw_bar_scaled_coord_on_linear_buffer(dest, x * scale, y1 * scale, scale, span * scale, color, pitch, screen_width, screen_height)

def draw_logical_bar_on_linear_buffer(dest: mutable u8&, x: i32, y: i32, width: i32, height: i32, color: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        if scale <= 0:
            return -1

        return draw_bar_scaled_coord_on_linear_buffer(dest, x * scale, y * scale, width * scale, height * scale, color, pitch, screen_width, screen_height)

def vwb_bar_on_linear_buffer(dest: mutable u8&, x: i32, y: i32, width: i32, height: i32, color: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return draw_logical_bar_on_linear_buffer(dest, x, y, width, height, color, pitch, scale, screen_width, screen_height)

def vwb_plot_on_linear_buffer(dest: mutable u8&, x: i32, y: i32, color: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return draw_logical_plot_on_linear_buffer(dest, x, y, color, pitch, scale, screen_width, screen_height)

def vwb_hlin_on_linear_buffer(dest: mutable u8&, x1: i32, x2: i32, y: i32, color: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture, Video.Geometry]:
    can Video.Picture, Video.Geometry:
        return draw_logical_hline_on_linear_buffer(dest, x1, x2, y, color, pitch, scale, screen_width, screen_height)

def vwb_vlin_on_linear_buffer(dest: mutable u8&, y1: i32, y2: i32, x: i32, color: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture, Video.Geometry]:
    can Video.Picture, Video.Geometry:
        return draw_logical_vline_on_linear_buffer(dest, y1, y2, x, color, pitch, scale, screen_width, screen_height)

def vwb_draw_prop_string_on_linear_buffer(text: u8&, font_base: u8&, font_locations: i16&, font_width: u8&, dest: mutable u8&, font_height: i32, scale: i32, dest_pitch: i32, color: i32) -> i32 can[Video.Text, Video.Picture]:
    can Video.Text, Video.Picture:
        return draw_prop_string_scaled(text, font_base, font_locations, font_width, dest, font_height, scale, dest_pitch, color)

def vwb_draw_pic_on_linear_buffer(source: u8&, width: i32, height: i32, dest: mutable u8&, x: i32, y: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return draw_planar_block_on_linear_buffer(source, dest, width, height, x, y, scale, pitch, screen_width, screen_height)

def vwb_draw_pic_scaled_coord_on_linear_buffer(source: u8&, width: i32, height: i32, dest: mutable u8&, x: i32, y: i32, pitch: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return draw_planar_block_on_linear_buffer(source, dest, width, height, x, y, scale, pitch, screen_width, screen_height)

def latch_draw_pic_on_screen(picnum: i32, x: i32, y: i32) -> i32 can[Game.Run, Video.Picture, Video.Surface, Unsafe.RawExtern]:
    can Game.Run, Video.Picture, Video.Surface, Unsafe.RawExtern:
        index: i32 = latchpic_index(picnum, wolf3d_latchpics_lump_start)
        surface: mutable void&? = wolf3d_legacy_get_latchpic_surface(index)
        if surface == null:
            return -1

        width: mutable i32 = 0
        height: mutable i32 = 0
        if wolf3d_legacy_get_latchpic_dimensions(picnum, width, height) != 0:
            return -1

        scale: i32 = wolf3d_legacy_get_scale_factor()
        return wolf3d_legacy_vl_latch_to_screen_scaled_coord(surface, 0, 0, width, height, scale * x * 8, scale * y)

def latch_draw_pic_scaled_coord_on_screen(picnum: i32, scx: i32, scy: i32) -> i32 can[Game.Run, Video.Picture, Video.Surface, Unsafe.RawExtern]:
    can Game.Run, Video.Picture, Video.Surface, Unsafe.RawExtern:
        index: i32 = latchpic_index(picnum, wolf3d_latchpics_lump_start)
        surface: mutable void&? = wolf3d_legacy_get_latchpic_surface(index)
        if surface == null:
            return -1

        width: mutable i32 = 0
        height: mutable i32 = 0
        if wolf3d_legacy_get_latchpic_dimensions(picnum, width, height) != 0:
            return -1

        scale: i32 = wolf3d_legacy_get_scale_factor()
        return wolf3d_legacy_vl_latch_to_screen_scaled_coord(surface, 0, 0, width, height, scale * scx * 8, scale * scy)

def vh_update_screen(screen_buffer: mutable void&?, screen: mutable void&?) -> i32 can[Video.Surface, Unsafe.RawExtern]:
    can Video.Surface, Unsafe.RawExtern:
        _ = sdl_blit_surface_raw(screen_buffer, null, screen, null)
        crt_dac_raw()
    return 0

def draw_planar_block_on_linear_buffer(source: u8&, dest: mutable u8&, width: i32, height: i32, dest_x: i32, dest_y: i32, scale: i32, dest_pitch: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        if validate_scaled_draw_bounds(dest_x, dest_y, width, height, scale, screen_width, screen_height) != 0:
            return -1
        return draw_planar_scaled_to_linear(source, dest, width, height, dest_x, dest_y, scale, dest_pitch)

def draw_planar_region_on_linear_buffer(source: u8&, dest: mutable u8&, orig_width: i32, orig_height: i32, src_x: i32, src_y: i32, dest_x: i32, dest_y: i32, width: i32, height: i32, scale: i32, dest_pitch: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        if validate_scaled_draw_bounds(dest_x, dest_y, width, height, scale, screen_width, screen_height) != 0:
            return -1
        return draw_planar_region_scaled_to_linear(source, dest, orig_width, orig_height, src_x, src_y, dest_x, dest_y, width, height, scale, dest_pitch)

def draw_prop_string_scaled(text: u8&, font_base: u8&, font_locations: i16&, font_width: u8&, dest: mutable u8&, font_height: i32, scale: i32, dest_pitch: i32, color: i32) -> i32 can[Video.Text, Video.Picture]:
    if font_height < 0 or scale <= 0:
        return -1

    drawn_width: mutable i32 = 0
    text_index: mutable usize = 0
    dest_column: mutable usize = 0

    can Video.Text:
        signal Video.Text

    can Video.Picture:
        signal Video.Picture

        scale_usize: usize = scale.usize()
        pitch: usize = dest_pitch.usize()
        value: u8 = color.u8()

        while text[text_index] != 0.u8():
            ch: usize = text[text_index].usize()
            width: i32 = font_width[ch].i32()
            step: usize = width.usize()
            glyph_offset: usize = font_locations[ch].usize()

            for x in 0..<step:
                for y in 0..<font_height.usize():
                    if font_base[glyph_offset + x + y * step] != 0.u8():
                        for sy in 0..<scale_usize:
                            for sx in 0..<scale_usize:
                                dest[(y * scale_usize + sy) * pitch + dest_column + x * scale_usize + sx] <- value

            drawn_width <- drawn_width + width
            dest_column <- dest_column + step * scale_usize
            text_index <- text_index + 1

    return drawn_width

def apply_fizzle_pixels(source: u8&, dest: mutable u8&, x1: i32, y1: i32, width: i32, height: i32, source_pitch: i32, dest_pitch: i32, rndbits_y: i32, rndmask: u32, pixperframe: u32, start_rndval: u32) -> u32 can[Video.Fizzle, Video.Picture]:
    rndval: mutable u32 = start_rndval
    copied: mutable u32 = 0

    can Video.Fizzle:
        signal Video.Fizzle

    can Video.Picture:
        signal Video.Picture

        y_mask: u32 = (1.u32() << rndbits_y.u32()) - 1.u32()
        x_origin: usize = x1.usize()
        y_origin: usize = y1.usize()
        source_pitch_usize: usize = source_pitch.usize()
        dest_pitch_usize: usize = dest_pitch.usize()

        while copied < pixperframe:
            x: u32 = rndval >> rndbits_y.u32()
            y: u32 = rndval & y_mask

            can Video.Fizzle:
                rndval <- fizzle_advance(rndval, rndmask)

            if x >= width.u32() or y >= height.u32():
                if rndval == 0.u32():
                    return 0.u32()
            else:
                offset_source: usize = (y_origin + y.usize()) * source_pitch_usize + x_origin + x.usize()
                offset_dest: usize = (y_origin + y.usize()) * dest_pitch_usize + x_origin + x.usize()
                dest[offset_dest] <- source[offset_source]

                if rndval == 0.u32():
                    return 0.u32()

                copied <- copied + 1.u32()

    return rndval

def fizzle_fade_on_locked_buffers(source_pixels: u8&, source_pitch: i32, screen_copy_pixels: mutable u8&, screen_copy_pitch: i32, x1: i32, y1: i32, width: i32, height: i32, frames: u32, abortable: i32, usedoublebuffering: i32, rndbits_y: i32, rndmask: u32, source_width: i32, source_height: i32, screen_width: i32, screen_height: i32, screen_copy: mutable void&?, screen_buffer: mutable void&?, screen: mutable void&?) -> i32 can[Game.Run, Video.Fizzle, Video.Picture, Video.Surface, Unsafe.RawExtern]:
    if validate_fizzle_work_area(x1, y1, width, height, source_width, source_height, screen_width, screen_height) != 0:
        return 1
    if validate_fizzle_frames(frames) != 0:
        return 1

    pixperframe: u32 = fizzle_pixels_per_frame(width.u32(), height.u32(), frames)
    _ = wolf3d_legacy_in_start_ack()

    frame: mutable u32 = (sdl_get_ticks_raw() * 7.u32()) / 100.u32()
    lastrndval: mutable u32 = 0.u32()
    first: mutable i32 = 1

    while true:
        if abortable != 0 and wolf3d_legacy_in_check_ack() != 0:
            _ = sdl_blit_surface_raw(screen_copy, null, screen_buffer, null)
            _ = sdl_blit_surface_raw(screen_buffer, null, screen, null)
            crt_dac_raw()
            return 1

        rndval: mutable u32 = lastrndval
        for i in first..<2:
            rndval <- apply_fizzle_pixels(source_pixels, screen_copy_pixels, x1, y1, width, height,
                source_pitch, screen_copy_pitch, rndbits_y, rndmask, pixperframe, rndval)
            if i == 0 or first != 0:
                lastrndval <- rndval
            if rndval == 0.u32():
                _ = sdl_blit_surface_raw(screen_copy, null, screen_buffer, null)
                _ = sdl_blit_surface_raw(screen_buffer, null, screen, null)
                crt_dac_raw()
                return 0

        first <- next_fizzle_first(usedoublebuffering, first)
        _ = sdl_blit_surface_raw(screen_copy, null, screen_buffer, null)
        _ = sdl_blit_surface_raw(screen_buffer, null, screen, null)
        crt_dac_raw()

        frame <- frame + 1.u32()
        current: u32 = (sdl_get_ticks_raw() * 7.u32()) / 100.u32()
        if frame > current:
            sdl_delay_raw(((frame - current) * 100.u32()) / 7.u32())

    return 1

def checked_measure_prop_string_width(text: u8&, font_width: u8&) -> i32 can[Video.Text]:
    width: mutable i32 = 0
    index: mutable usize = 0

    can Video.Text:
        signal Video.Text

        while text[index] != 0.u8():
            width <- width + font_width[text[index].usize()].i32()
            index <- index + 1

    return width

def measure_prop_string_width(text: u8&, font_width: u8&) -> i32 can[Video.Text]:
    can Video.Text:
        return checked_measure_prop_string_width(text, font_width)

def measure_prop_string(text: u8&, width: mutable u16&, height: mutable u16&, font_height: i32, font_width: u8&) -> i32 can[Video.Text]:
    if font_height < 0:
        return -1

    can Video.Text:
        signal Video.Text
        width[0] <- measure_prop_string_width(text, font_width).u16()
        height[0] <- font_height.u16()

    return 0

def checked_measure_prop_string_safe(text: u8&?, width: mutable u16&?, height: mutable u16&?, font_height: i32, font_width: u8&?) -> i32 error[VideoTextMeasureError] can[Video.Text]:
    if text == null:
        raise VideoTextMeasureError.NullPointer
    if width == null:
        raise VideoTextMeasureError.NullPointer
    if height == null:
        raise VideoTextMeasureError.NullPointer

    if font_width == null:
        raise VideoTextMeasureError.NullPointer
    if font_height < 0:
        raise VideoTextMeasureError.InvalidFontHeight

    can Video.Text:
        signal Video.Text
        width[0] <- measure_prop_string_width(text, font_width).u16()
        height[0] <- font_height.u16()

    return 0

def measure_prop_string_safe(text: u8&?, width: mutable u16&?, height: mutable u16&?, font_height: i32, font_width: u8&?) -> i32 can[Video.Text]:
    can Video.Text:
        return try checked_measure_prop_string_safe(text, width, height, font_height, font_width) else -1

def checked_inclusive_span_length(start: i32, end: i32) -> i32 error[VideoCoordinateError] can[Video.Geometry]:
    if end < start.i32():
        raise VideoCoordinateError.OutOfBounds

    can Video.Geometry:
        signal Video.Geometry

    return end - start + 1

def inclusive_span_length(start: i32, end: i32) -> i32 can[Video.Geometry]:
    can Video.Geometry:
        return try checked_inclusive_span_length(start, end) else -1

def checked_fizzle_frames(frames: u32) -> i32 error[VideoFadeError] can[Video.Fizzle]:
    if frames == 0.u32():
        raise VideoFadeError.ZeroFrames

    can Video.Fizzle:
        signal Video.Fizzle

    return 0

def validate_fizzle_frames(frames: u32) -> i32 can[Video.Fizzle]:
    can Video.Fizzle:
        return try checked_fizzle_frames(frames) else -1

def checked_fade_steps(steps: i32) -> i32 error[VideoFadeError] can[Video.Palette]:
    if steps <= 0.i32():
        raise VideoFadeError.ZeroSteps

    can Video.Palette:
        signal Video.Palette
    return 0

def validate_fade_steps(steps: i32) -> i32 can[Video.Palette]:
    can Video.Palette:
        return try checked_fade_steps(steps) else -1

def checked_palette_index(color: i32) -> i32 error[VideoColorError] can[Video.Palette]:
    if color < 0.i32() or color >= 256.i32():
        raise VideoColorError.PaletteIndexOutOfRange

    can Video.Palette:
        signal Video.Palette
    return 0

def validate_palette_index(color: i32) -> i32 can[Video.Palette]:
    can Video.Palette:
        return try checked_palette_index(color) else -1

def checked_scaled_draw_bounds(dest_x: i32, dest_y: i32, width: i32, height: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 error[VideoCoordinateError] can[Video.Picture]:
    if scale <= 0.i32():
        raise VideoCoordinateError.NonPositiveScale

    if width < 0.i32() or height < 0.i32():
        raise VideoCoordinateError.OutOfBounds

    if dest_x < 0.i32() or dest_y < 0.i32():
        raise VideoCoordinateError.OutOfBounds

    scaled_width: i64 = width.i64() * scale.i64()
    scaled_height: i64 = height.i64() * scale.i64()

    if scaled_width < 0.i64() or scaled_height < 0.i64():
        raise VideoCoordinateError.OutOfBounds

    right: i64 = dest_x.i64() + scaled_width
    bottom: i64 = dest_y.i64() + scaled_height
    if right > screen_width.i64() or bottom > screen_height.i64():
        raise VideoCoordinateError.OutOfBounds

    can Video.Picture:
        signal Video.Picture
    return 0

def checked_rect_bounds(dest_x: i32, dest_y: i32, width: i32, height: i32, screen_width: i32, screen_height: i32) -> i32 error[VideoCoordinateError] can[Video.Picture]:
    if dest_x < 0.i32() or dest_y < 0.i32():
        raise VideoCoordinateError.OutOfBounds

    if width < 0.i32() or height < 0.i32():
        raise VideoCoordinateError.OutOfBounds

    right: i64 = dest_x.i64() + width.i64()
    bottom: i64 = dest_y.i64() + height.i64()

    if right > screen_width.i64() or bottom > screen_height.i64():
        raise VideoCoordinateError.OutOfBounds

    can Video.Picture:
        signal Video.Picture
    return 0

def checked_hline_bounds(dest_x: i32, dest_y: i32, width: i32, screen_width: i32, screen_height: i32) -> i32 error[VideoCoordinateError] can[Video.Picture]:
    can Video.Picture:
        return checked_rect_bounds(dest_x, dest_y, width, 1.i32(), screen_width, screen_height)

def checked_vline_bounds(dest_x: i32, dest_y: i32, height: i32, screen_width: i32, screen_height: i32) -> i32 error[VideoCoordinateError] can[Video.Picture]:
    can Video.Picture:
        return checked_rect_bounds(dest_x, dest_y, 1.i32(), height, screen_width, screen_height)

def checked_bar_bounds(dest_x: i32, dest_y: i32, width: i32, height: i32, screen_width: i32, screen_height: i32) -> i32 error[VideoCoordinateError] can[Video.Picture]:
    can Video.Picture:
        return checked_rect_bounds(dest_x, dest_y, width, height, screen_width, screen_height)

def checked_mem_to_latch_bounds(dest_x: i32, dest_y: i32, width: i32, height: i32, surface_width: i32, surface_height: i32) -> i32 error[VideoCoordinateError] can[Video.Picture]:
    can Video.Picture:
        return checked_rect_bounds(dest_x, dest_y, width, height, surface_width, surface_height)

def validate_scaled_draw_bounds(dest_x: i32, dest_y: i32, width: i32, height: i32, scale: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return try checked_scaled_draw_bounds(dest_x, dest_y, width, height, scale, screen_width, screen_height) else -1

def validate_hline_bounds(dest_x: i32, dest_y: i32, width: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return try checked_hline_bounds(dest_x, dest_y, width, screen_width, screen_height) else -1

def validate_vline_bounds(dest_x: i32, dest_y: i32, height: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return try checked_vline_bounds(dest_x, dest_y, height, screen_width, screen_height) else -1

def validate_bar_bounds(dest_x: i32, dest_y: i32, width: i32, height: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return try checked_bar_bounds(dest_x, dest_y, width, height, screen_width, screen_height) else -1

def validate_mem_to_latch_bounds(dest_x: i32, dest_y: i32, width: i32, height: i32, surface_width: i32, surface_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return try checked_mem_to_latch_bounds(dest_x, dest_y, width, height, surface_width, surface_height) else -1

def checked_fizzle_work_area(dest_x: i32, dest_y: i32, width: i32, height: i32, source_width: i32, source_height: i32, screen_width: i32, screen_height: i32) -> i32 error[VideoCoordinateError] can[Video.Picture]:
    if width <= 0.i32() or height <= 0.i32():
        raise VideoCoordinateError.OutOfBounds

    if dest_x < 0.i32() or dest_y < 0.i32():
        raise VideoCoordinateError.OutOfBounds

    src_right: i64 = dest_x.i64() + width.i64()
    src_bottom: i64 = dest_y.i64() + height.i64()
    screen_right: i64 = dest_x.i64() + width.i64()
    screen_bottom: i64 = dest_y.i64() + height.i64()

    if src_right > source_width.i64() or src_bottom > source_height.i64():
        raise VideoCoordinateError.OutOfBounds

    if screen_right > screen_width.i64() or screen_bottom > screen_height.i64():
        raise VideoCoordinateError.OutOfBounds

    can Video.Picture:
        signal Video.Picture
    return 0

def validate_fizzle_work_area(dest_x: i32, dest_y: i32, width: i32, height: i32, source_width: i32, source_height: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return try checked_fizzle_work_area(dest_x, dest_y, width, height, source_width, source_height, screen_width, screen_height) else -1

def validate_pixel_bounds(dest_x: i32, dest_y: i32, screen_width: i32, screen_height: i32) -> i32 can[Video.Picture]:
    can Video.Picture:
        return try checked_rect_bounds(dest_x, dest_y, 1.i32(), 1.i32(), screen_width, screen_height) else -1

def fade_scale_6bit_color_component(component: i32) -> i32 can[Video.Palette]:
    can Video.Palette:
        signal Video.Palette
    return component * 255 / 63

def fade_interpolated_channel(origin: i32, target: i32, frame: i32, steps: i32) -> i32 can[Video.Palette]:
    can Video.Palette:
        signal Video.Palette
    return origin + (target - origin) * frame / steps

def convert_palette_6bit_rgb_to_sdl_colors(src: u8&, dst: mutable u8&, count: i32) -> i32 can[Video.Palette]:
    if count <= 0:
        return 0

    can Video.Palette:
        signal Video.Palette

        for i in 0..<count.usize():
            src_base: usize = i * 3
            dst_base: usize = i * 4
            dst[dst_base] <- (src[src_base].i32() * 255 / 63).u8()
            dst[dst_base + 1] <- (src[src_base + 1].i32() * 255 / 63).u8()
            dst[dst_base + 2] <- (src[src_base + 2].i32() * 255 / 63).u8()

    return count

def fill_sdl_palette_rgb(dst: mutable u8&, red: i32, green: i32, blue: i32, count: i32) -> i32 can[Video.Palette]:
    if count <= 0:
        return 0

    can Video.Palette:
        signal Video.Palette

        for i in 0..<count.usize():
            base: usize = i * 4
            dst[base] <- red.u8()
            dst[base + 1] <- green.u8()
            dst[base + 2] <- blue.u8()

    return count

def copy_sdl_palette(src: u8&, dst: mutable u8&, count: i32) -> i32 can[Video.Palette]:
    if count <= 0:
        return 0

    can Video.Palette:
        signal Video.Palette

        for i in 0..<count.usize():
            base: usize = i * 4
            dst[base] <- src[base]
            dst[base + 1] <- src[base + 1]
            dst[base + 2] <- src[base + 2]
            dst[base + 3] <- src[base + 3]

    return count

def validate_palette_range(start: i32, end: i32, count: i32) -> i32 error[VideoColorError] can[Video.Palette]:
    if start < 0 or end < start or end >= count:
        raise VideoColorError.PaletteIndexOutOfRange

    can Video.Palette:
        signal Video.Palette

    return 0

def build_fade_out_sdl_palette(origin: u8&, dst: mutable u8&, start: i32, end: i32, red: i32, green: i32, blue: i32, frame: i32, steps: i32, count: i32) -> i32 can[Video.Palette]:
    can Video.Palette:
        _ = try validate_palette_range(start, end, count) else return -1
        _ = try checked_fade_steps(steps) else return -1
        _ = copy_sdl_palette(origin, dst, count)

        target_red: i32 = fade_scale_6bit_color_component(red)
        target_green: i32 = fade_scale_6bit_color_component(green)
        target_blue: i32 = fade_scale_6bit_color_component(blue)

        for i in start.usize()..<(end + 1).usize():
            base: usize = i * 4
            dst[base] <- fade_interpolated_channel(origin[base].i32(), target_red, frame, steps).u8()
            dst[base + 1] <- fade_interpolated_channel(origin[base + 1].i32(), target_green, frame, steps).u8()
            dst[base + 2] <- fade_interpolated_channel(origin[base + 2].i32(), target_blue, frame, steps).u8()

    return 0

def build_fade_in_sdl_palette(origin: u8&, target: u8&, dst: mutable u8&, start: i32, end: i32, frame: i32, steps: i32, count: i32) -> i32 can[Video.Palette]:
    can Video.Palette:
        _ = try validate_palette_range(start, end, count) else return -1
        _ = try checked_fade_steps(steps) else return -1
        _ = copy_sdl_palette(origin, dst, count)

        for i in start.usize()..<(end + 1).usize():
            base: usize = i * 4
            dst[base] <- fade_interpolated_channel(origin[base].i32(), target[base].i32(), frame, steps).u8()
            dst[base + 1] <- fade_interpolated_channel(origin[base + 1].i32(), target[base + 1].i32(), frame, steps).u8()
            dst[base + 2] <- fade_interpolated_channel(origin[base + 2].i32(), target[base + 2].i32(), frame, steps).u8()

    return 0

def build_palette_shift_table(base_palette: u8&, dst: mutable u8&, frames: i32, steps: i32, target_red: i32, target_green: i32, target_blue: i32, count: i32) -> i32 can[Video.Palette]:
    if frames < 0 or steps <= 0 or count < 0:
        return -1

    can Video.Palette:
        signal Video.Palette

        for frame in 1..<(frames + 1).usize():
            frame_i32: i32 = frame.i32()
            frame_base: usize = (frame - 1) * count.usize() * 4

            for color in 0..<count.usize():
                base: usize = color * 4
                out: usize = frame_base + base
                red: i32 = base_palette[base].i32()
                green: i32 = base_palette[base + 1].i32()
                blue: i32 = base_palette[base + 2].i32()

                dst[out] <- (red + (target_red - red) * frame_i32 / steps).u8()
                dst[out + 1] <- (green + (target_green - green) * frame_i32 / steps).u8()
                dst[out + 2] <- (blue + (target_blue - blue) * frame_i32 / steps).u8()

    return 0

def fizzle_bits_for_dimensions(width: u32, height: u32) -> i32 can[Video.Fizzle, Video.Geometry]:
    can Video.Fizzle:
        signal Video.Fizzle
    can Video.Geometry:
        signal Video.Geometry

    bits: mutable i32 = 0
    can Video.Fizzle, Video.Geometry:
        bits_x: i32 = log2_ceil_impl(width)
        bits_y: i32 = log2_ceil_impl(height)
        bits <- bits_x + bits_y

    if bits < 17:
        return 17
    if bits > 25:
        return 25
    return bits

def fizzle_mask_for_dimensions(width: u32, height: u32) -> u32 can[Video.Fizzle, Video.Geometry]:
    can Video.Fizzle:
        signal Video.Fizzle
    can Video.Geometry:
        signal Video.Geometry

    can Video.Fizzle, Video.Geometry:
        return fizzle_mask_for_bits(fizzle_bits_for_dimensions(width, height))

